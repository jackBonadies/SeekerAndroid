<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:animateLayoutChanges="true"
    android:layout_height="match_parent"
>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/current_ticker"
        android:padding="6dp"
        android:minLines="1"
        android:maxLines="2"
        android:clickable="true"
        android:ellipsize="end"
        android:text="@string/chatroom_loading_ticker"
        android:background="@drawable/room_statuses_background"
    />
    <Seeker.RecyclerView2
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:id="@+id/room_statuses_recycler_view"
        android:clickable="true"
        android:paddingBottom="4dp"
        android:background="@drawable/room_statuses_background"
    />
    <RelativeLayout
        android:id="@+id/test1"
        android:layout_width="match_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"
    >
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_messages"
            android:layout_height="fill_parent"
            android:layout_width="match_parent"
        />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:visibility="gone"
            android:background="?attr/floating_action_bar_to_bottom_background"
            android:backgroundTint="?attr/floating_action_bar_to_bottom_background"
            android:tint="?attr/floating_action_bar_to_bottom_icon"
            app:backgroundTint="?attr/floating_action_bar_to_bottom_background"
            app:fabSize="mini"
            android:elevation="1000dp"
            android:translationZ="100dp"
            android:id="@+id/bsbutton"
            android:layout_marginBottom="16dp"
            android:layout_marginRight="16dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"
        />

        <ViewFlipper
            android:id="@+id/joinEmptyStateFlipper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center_horizontal"
            android:inAnimation="@null"
            android:outAnimation="@null"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/joinPendingView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/joinPendingSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:indicatorSize="120dp"
                    app:trackCornerRadius="5dp"
                    app:trackThickness="6dp"
                    app:indicatorColor="?attr/mainPurple"
                    android:indeterminateOnly="true" />

                <TextView
                    android:id="@+id/joinPendingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?attr/cellTextColor"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/joinFailedView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/chat_error96dp"
                    android:tint="?attr/cellTextColorSubdued" />

                <TextView
                    android:id="@+id/joinFailedMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="?attr/cellTextColor"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/joinFailedSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
					android:gravity="center_horizontal"
                    android:textSize="14sp"
                    android:textColor="?attr/cellTextColorSubdued"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/joinFailedRetry"
                    style="@style/SeekerButtonStyle"
                    android:foreground="@drawable/button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:text="@string/retry" />

            </LinearLayout>

        </ViewFlipper>
    </RelativeLayout>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_weight="0"
        android:background="@color/chatBoxSplitterElevation"
    />

    <RelativeLayout
        android:id="@+id/layout_gchat_chatbox"
        android:layout_width="match_parent"
        android:layout_weight="0"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
    >
        <EditText
            android:id="@+id/edit_gchat_message"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/button_gchat_send"
            android:layout_marginEnd="8dp"
            android:background="?attr/chatInputBackground"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:hint="@string/chatroom_enter_message"
            android:inputType="text"
            android:singleLine="true"
            android:imeOptions="actionSend"
            tools:ignore="Autofill"
        />

        <ImageButton
            android:id="@+id/button_gchat_send"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_send"
            android:tint="?attr/mainTextColor"
            android:contentDescription="@string/send_message"
            android:enabled="false"
        />
    </RelativeLayout>
</LinearLayout>
