<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchResultSelection"
    android:orientation="vertical"
    android:paddingBottom="20dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
	android:background="@drawable/bottom_sheet_header_bg"
	android:backgroundTint="?attr/searchBottomSheetBackground"
>
	<View
		android:layout_width="32dp"
		android:layout_height="4dp"
		android:layout_gravity="center_horizontal"
		android:layout_marginTop="8dp"
		android:layout_marginBottom="8dp"
		android:background="@drawable/search_bottom_sheet_drag_handle"
	/>

    <TextView
        android:paddingBottom="2dp"
        android:paddingTop="4dp"
        android:paddingEnd="2dp"
        android:paddingStart="2dp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:text="@string/search_result_style"
        android:textSize="22sp"
        android:textColor="?attr/searchTabHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
    />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="2dp"
        android:textColor="?attr/cellTextColorSubdued"
        android:text="@string/search_result_style_style_label"
        android:textAllCaps="true"
        android:textSize="11sp"
        android:letterSpacing="0.08"
    />
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/styleToggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:singleSelection="true"
        app:selectionRequired="true"
    >
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStyleModern"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_modern"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStyleSimple"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_simple"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStyleCompact"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_compact"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/bitrateToggleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="2dp"
        android:text="@string/search_result_style_filetype_position_label"
        android:textColor="?attr/cellTextColorSubdued"
        android:textAllCaps="true"
        android:textSize="11sp"
        android:letterSpacing="0.08"
    />
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/bitrateToggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:singleSelection="true"
        app:selectionRequired="true"
    >
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBitrateTop"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_filetype_top"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBitrateBottom"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_filetype_bottom"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/expandableToggleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="2dp"
        android:text="@string/search_result_style_expandable"
        android:textColor="?attr/cellTextColorSubdued"
        android:textAllCaps="true"
        android:textSize="11sp"
        android:letterSpacing="0.08"
    />
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/expandableToggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:singleSelection="true"
        app:selectionRequired="true"
    >
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExpandableOff"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_off"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExpandableOn"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/search_result_style_on"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
        />
    </com.google.android.material.button.MaterialButtonToggleGroup>
</LinearLayout>
