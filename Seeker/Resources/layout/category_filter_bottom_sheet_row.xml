<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">
    <View
        android:id="@+id/categoryFilterRowTopSeparator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slightTint"
        android:visibility="gone" />
    <LinearLayout
        android:id="@+id/categoryFilterRowHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:minHeight="20dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/categoryFilterRowCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="false"
            android:focusable="false"
			android:layout_margin="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:scaleX="1"
            android:scaleY="1"
            app:minTouchTargetSize="0dp" />
        <TextView
			android:layout_marginStart="4dp"
            android:id="@+id/categoryFilterRowText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?attr/normalTextColor" />
        <TextView
            android:id="@+id/categoryFilterRowCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:textSize="13sp"
            android:textColor="?attr/cellTextColorSubdued" />
    </LinearLayout>
</LinearLayout>
