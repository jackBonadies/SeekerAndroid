<?xml version="1.0" encoding="utf-8" ?>
<ViewFlipper
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginViewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>
    <!-- Child 0: Login form -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:id="@+id/logInLayout"
        android:gravity="center_horizontal" 
		android:orientation="vertical"
    >
		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/login"
			android:layout_marginTop="25dp"
			android:id="@+id/textView"
            android:textStyle="bold"
            android:textColor="?attr/mainTextColor"
			android:textSize="35sp"
        />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/signin_or_create_account"
			android:layout_marginTop="7dp"
			android:id="@+id/loginSubText"
			android:textColor="@color/subTextColor"
			android:textSize="14sp"
        />

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/usernameTextInputLayout"
			android:layout_marginTop="38dp"
			style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
			app:errorEnabled="false"
			app:hintEnabled="false"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
        >
			<com.google.android.material.textfield.TextInputEditText
				android:textColorHighlight="?attr/mainTextColor"
				android:textColorHint="?attr/mainTextColor"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:singleLine="true"
				android:focusable="true"
				android:id="@+id/etUsername"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:ems="10"
				android:inputType="textNoSuggestions"
				android:hint="@string/username"
            />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/passwordTextInputLayout"
			android:layout_marginTop="15dp"
			app:passwordToggleEnabled="true"
			style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
			app:errorEnabled="false"
			app:hintEnabled="false"
			android:singleLine="true"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
        >
			<EditText
				android:textColorHighlight="?attr/mainTextColor"
				android:textColorHint="?attr/mainTextColor"
				android:layout_marginBottom="0dp"
				android:layout_marginTop="0dp"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:focusable="true"
				android:id="@+id/etPassword"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:gravity="center_vertical"
				android:ems="10"
				android:inputType="textPassword"
				android:hint="@string/password"
            />
		</com.google.android.material.textfield.TextInputLayout>

		<Button
			android:layout_marginLeft="44dp"
			android:layout_marginRight="44dp"
			android:layout_marginTop="20dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:foreground="?android:attr/selectableItemBackground"
			style="@style/SeekerButtonStyle"
			android:text="@string/signin"
			android:id="@+id/buttonLogin"
			android:layout_below="@+id/passwordTextInputLayout"
        />

		<TextView
			android:layout_marginStart="6dp"
			android:layout_marginTop="6dp"
			android:layout_marginBottom="6dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/no_account"
			android:id="@+id/noAccount"
			android:gravity="center"
			android:textColor="@color/subTextColor"
			android:textSize="14sp"
        />
	</LinearLayout>

    <!-- Child 1: Loading spinner -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/loggingInLayout"
    >
        <Seeker.MaterialProgressBarPassThrough
            android:id="@+id/loggingInLoadingCircle"
            android:layout_marginTop="140dp"
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
        />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/connectingToServer"
            android:layout_below="@id/loggingInLoadingCircle"
            android:layout_marginTop="20dp"
            android:textColor="?attr/normalTextColor"
            android:text="@string/ConnectingToServer"
            android:layout_centerHorizontal="true"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_below="@id/connectingToServer"
            android:id="@+id/pleaseWait"
            android:textColor="?attr/normalTextColor"
            android:text="@string/PleaseWait_"
            android:layout_centerHorizontal="true"
        />
    </RelativeLayout>

    <!-- Child 2: Logged-in screen -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/loggedInLayout"
    >
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:id="@+id/loggedInCard"
        >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
            >
                <!-- Left side: label + username -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/logged_in_as"
                        android:textColor="@color/subTextColor"
                        android:textSize="14sp"
                    />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/userNameView"
                        android:textColor="?attr/normalTextColor"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginTop="2dp"
                    />
                </LinearLayout>

                <!-- Right side: chip-like status badge -->
                <LinearLayout
                    android:id="@+id/connectionStatusChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/connection_status_chip_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                >
                    <View
                        android:id="@+id/connectionStatusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/connection_status_dot"
                    />
                    <TextView
                        android:id="@+id/connectionStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_connected"
                        android:textSize="13sp"
                        android:textColor="#2E7D32"
                        android:layout_marginStart="6dp"
                    />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <Button
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_a_download_folder"
            android:foreground="@drawable/button"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="260dp"
            android:layout_marginBottom="40dp"
            style="@style/SeekerButtonStyle"
            android:id="@+id/mustSelectDirectory"
            android:visibility="gone"
        />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/loggedInCard"
            android:fillViewport="true"
        >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp"
            >
                <!-- SETUP section -->
                <TextView
                    android:id="@+id/menuSetupHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_caps_setup"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/subTextColor"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                />

                <!-- Set Up Sharing row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuSetUpSharing"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                    >
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/upload_material"
                            app:tint="@color/subTextColor"
                        />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/set_up_sharing"
                            android:textSize="16sp"
                            android:textColor="?attr/normalTextColor"
                            android:layout_marginStart="16dp"
                        />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_right"
                            app:tint="@color/subTextColor"
                        />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Manage User List row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuManageUserList"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                    >
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/baseline_group_white_24"
                            app:tint="@color/subTextColor"
                        />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/manage_user_list"
                            android:textSize="16sp"
                            android:textColor="?attr/normalTextColor"
                            android:layout_marginStart="16dp"
                        />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_right"
                            app:tint="@color/subTextColor"
                        />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- COMMUNICATION section -->
                <TextView
                    android:id="@+id/menuCommunicationHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_caps_communication"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/subTextColor"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                />

                <!-- Messages row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuMessages"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                    >
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/baseline_chat_bubble_white_24"
                            app:tint="@color/subTextColor"
                        />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/messages"
                            android:textSize="16sp"
                            android:textColor="?attr/normalTextColor"
                            android:layout_marginStart="16dp"
                        />
                        <TextView
                            android:id="@+id/messagesUnreadBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/subTextColor"
                            android:layout_marginEnd="8dp"
                            android:visibility="gone"
                        />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_right"
                            app:tint="@color/subTextColor"
                        />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ACCOUNT section -->
                <TextView
                    android:id="@+id/menuAccountHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_caps_account"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/subTextColor"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                />

                <!-- Settings row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuSettings"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                    >
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/baseline_settings_white_24"
                            app:tint="@color/subTextColor"
                        />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings"
                            android:textSize="16sp"
                            android:textColor="?attr/normalTextColor"
                            android:layout_marginStart="16dp"
                        />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_right"
                            app:tint="@color/subTextColor"
                        />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Log Out row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuLogout"
                    style="@style/Widget.Material3.CardView.Elevated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="4dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                >
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                    >
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/logout_material"
                            app:tint="#F44336"
                        />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/logout"
                            android:textSize="16sp"
                            android:textColor="#F44336"
                            android:layout_marginStart="16dp"
                        />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_right"
                            app:tint="@color/subTextColor"
                        />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>
</ViewFlipper>
