<?xml version="1.0" encoding="utf-8" ?>
<ViewFlipper
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginViewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>
    <!-- Child 0: Login form -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:id="@+id/logInLayout"
        android:gravity="center_horizontal" 
		android:orientation="vertical"
    >
		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/login"
			android:layout_marginTop="25dp"
			android:id="@+id/textView"
            android:textStyle="bold"
            android:textColor="?attr/mainTextColor"
			android:textSize="35sp"
        />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/signin_or_create_account"
			android:layout_marginTop="7dp"
			android:id="@+id/loginSubText"
			android:textColor="@color/subTextColor"
			android:textSize="14sp"
        />

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/usernameTextInputLayout"
			android:layout_marginTop="38dp"
			style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
			app:errorEnabled="false"
			app:hintEnabled="false"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
        >
			<com.google.android.material.textfield.TextInputEditText
				android:textColorHighlight="?attr/mainTextColor"
				android:textColorHint="?attr/mainTextColor"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:singleLine="true"
				android:focusable="true"
				android:id="@+id/etUsername"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:ems="10"
				android:inputType="text"
				android:hint="@string/username"
            />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/passwordTextInputLayout"
			android:layout_marginTop="15dp"
			app:passwordToggleEnabled="true"
			style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
			app:errorEnabled="false"
			app:hintEnabled="false"
			android:singleLine="true"
			android:layout_marginLeft="40dp"
			android:layout_marginRight="40dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
        >
			<EditText
				android:textColorHighlight="?attr/mainTextColor"
				android:textColorHint="?attr/mainTextColor"
				android:layout_marginBottom="0dp"
				android:layout_marginTop="0dp"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:focusable="true"
				android:id="@+id/etPassword"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_gravity="center_vertical"
				android:gravity="center_vertical"
				android:ems="10"
				android:inputType="textPassword"
				android:hint="@string/password"
            />
		</com.google.android.material.textfield.TextInputLayout>

		<Button
			android:layout_marginLeft="44dp"
			android:layout_marginRight="44dp"
			android:layout_marginTop="20dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:foreground="?android:attr/selectableItemBackground"
			style="@style/SeekerButtonStyle"
			android:text="@string/signin"
			android:id="@+id/buttonLogin"
			android:layout_below="@+id/passwordTextInputLayout"
        />

		<TextView
			android:layout_marginStart="6dp"
			android:layout_marginTop="6dp"
			android:layout_marginBottom="6dp"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/no_account"
			android:id="@+id/noAccount"
			android:gravity="center"
			android:textColor="@color/subTextColor"
			android:textSize="14sp"
        />
	</LinearLayout>

    <!-- Child 1: Loading spinner -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/loggingInLayout"
    >
        <Seeker.MaterialProgressBarPassThrough
            android:id="@+id/loggingInLoadingCircle"
            android:layout_marginTop="140dp"
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
        />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/connectingToServer"
            android:layout_below="@id/loggingInLoadingCircle"
            android:layout_marginTop="20dp"
            android:textColor="?attr/normalTextColor"
            android:text="@string/ConnectingToServer"
            android:layout_centerHorizontal="true"
        />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_below="@id/connectingToServer"
            android:id="@+id/pleaseWait"
            android:textColor="?attr/normalTextColor"
            android:text="@string/PleaseWait_"
            android:layout_centerHorizontal="true"
        />
    </RelativeLayout>

    <!-- Child 2: Logged-in screen -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/loggedInLayout"
    >
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:id="@+id/loggedInCard"
        >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
            >
                <!-- Left side: label + username -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                >
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/logged_in_as"
                        android:textColor="@color/subTextColor"
                        android:textSize="14sp"
                    />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/userNameView"
                        android:textColor="?attr/mainTextColor"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginTop="2dp"
                    />
                </LinearLayout>

                <!-- Right side: status dot + text -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                >
                    <View
                        android:id="@+id/connectionStatusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/connection_status_dot"
                    />
                    <TextView
                        android:id="@+id/connectionStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_connected"
                        android:textSize="14sp"
                        android:layout_marginStart="6dp"
                    />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <Button
            android:foreground="@drawable/button"
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:layout_marginTop="35dp"
            style="@style/SeekerButtonStyle"
            android:id="@+id/buttonLogout"
            android:layout_below="@+id/loggedInCard"
        />

        <Button
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_a_download_folder"
            android:foreground="@drawable/button"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="260dp"
            android:layout_marginBottom="40dp"
            style="@style/SeekerButtonStyle"
            android:id="@+id/mustSelectDirectory"
            android:visibility="gone"
        />
        <Button
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:foreground="@drawable/button"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="50dp"
            style="@style/SeekerButtonStyle"
            android:layout_alignParentBottom="true"
            android:id="@+id/settingsButton"
        />
    </RelativeLayout>
</ViewFlipper>
