<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    tools:context="android.PageFragment"
    android:orientation="vertical"
    android:foreground="?android:attr/selectableItemBackground"
    android:id="@+id/linearLayoutMessageOverview"
>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
    >
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
        >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/username"
                android:text="usernameDummy"
                android:textSize="16sp"
                android:singleLine="true"
                android:ellipsize="end"
            />
            <ImageView
                android:id="@+id/statusIndicator"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                app:srcCompat="@drawable/checkbox_blank_circle"
                android:visibility="gone"
            />
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/dateTimeAgo"
            android:text="Dec 22"
            android:textSize="12sp"
            android:layout_gravity="center_vertical"
        />
        <ImageView
            android:id="@+id/selectionCheckbox"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            app:srcCompat="@drawable/check_circle_outline"
            android:visibility="gone"
        />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
    >
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="messageDummy"
            android:id="@+id/message"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
        />
        <TextView
            android:id="@+id/unreadBadge"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:minWidth="24dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:background="@drawable/unread_badge_background"
            android:textColor="@color/unreadBadgeText"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
        />
    </LinearLayout>
</LinearLayout>
