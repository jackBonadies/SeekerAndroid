<?xml version="1.0" encoding="utf-8" ?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
>
    <LinearLayout
        android:id="@+id/focusableLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:focusable="true"
        android:focusableInTouchMode="true"
    />
	<com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/linearProgressIndicator"
		android:layout_width="match_parent"
		android:layout_height="4dp"
		android:visibility="gone"
		app:trackCornerRadius="0dp"
		app:trackInnerCornerRadius="2dp"
		app:indicatorColor="?attr/mainPurple"
		android:indeterminateOnly="true" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true"
        tools:context="android.PageFragment"
        android:id="@+id/relativeLayout1"
    >
        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@id/header1"
            android:minWidth="25px"
            android:minHeight="0px"
            android:elevation="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/recyclerViewChips"
        />

        <View
            android:id="@+id/chipsSeparator"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/recyclerViewChips"
            android:background="@color/slightTint"
        />

        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@id/chipsSeparator"
            android:minWidth="25px"
            android:scrollbars="vertical"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:minHeight="25px"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/recyclerViewSearches"
        />
        <LinearLayout
            android:id="@+id/searchLoadingView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerInParent="true"
            android:translationY="-48dp"
            android:visibility="gone">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/searchLoadingSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:indicatorSize="120dp"
                app:trackCornerRadius="5dp"
                app:trackThickness="6dp"
                app:indicatorColor="?attr/mainPurple"
                android:indeterminateOnly="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/searching_label"
                android:textSize="18sp"
                android:textColor="?attr/cellTextColor"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/searchLoadingQueryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/noResultsView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerInParent="true"
            android:translationY="-48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/search_no_results"
                android:tint="?attr/cellTextColorSubdued" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_results_title"
                android:textSize="18sp"
                android:textColor="?attr/cellTextColor"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/noResultsSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/allFilteredView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerInParent="true"
            android:translationY="-48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/filter_list_96dp"
                android:tint="?attr/cellTextColorSubdued" />

            <TextView
                android:id="@+id/allFilteredTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="?attr/cellTextColor"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_hidden_subtitle"
                android:textSize="14sp"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/noSearchesView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_centerInParent="true"
            android:translationY="-48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/search"
                android:tint="?attr/cellTextColorSubdued" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_searches"
                android:textSize="18sp"
                android:textColor="?attr/cellTextColor"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_searches_subtitle"
                android:textSize="14sp"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </RelativeLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="@string/bottom_sheet_behavior"
        android:id="@+id/bottomSheet"
        android:background="@drawable/bottom_sheet_header_bg"
        android:backgroundTint="?attr/searchBottomSheetBackground"
    >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
        >
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/search_bottom_sheet_drag_handle"
            />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:id="@+id/filterLineOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="6dp"
                android:hint="@string/filter_search_results_here"
                app:boxBackgroundColor="?attr/dialog_background"
            >
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/filterText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:focusable="true"
                    android:imeOptions="actionDone"
                />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_format_label"
                android:textAllCaps="true"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
            />
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/formatToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@id/formatAny"
            >
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/formatAny"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_any"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/formatLossless"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_format_lossless"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/formatLossy"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_format_lossy"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"

                />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_min_bitrate_label"
                android:textAllCaps="true"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
            />
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/bitrateToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="4dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@id/bitrateAny"
            >
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bitrateAny"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_any"
                    android:textSize="10sp"
                    android:minWidth="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bitrate320"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="320"
                    android:textSize="10sp"
                    android:minWidth="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bitrate256"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="256"
                    android:textSize="10sp"
                    android:minWidth="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bitrate192"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="192"
                    android:textSize="10sp"
                    android:minWidth="0dp"

                />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bitrate128"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="128"
                    android:textSize="10sp"
                    android:minWidth="0dp"

                />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp"
                android:layout_height="wrap_content"
            >
                <Button
                    android:layout_marginTop="0dp"
                    style="@style/SeekerButtonStyle"
                    android:foreground="@drawable/button"
                    android:text="Show Smart Filters"
                    android:id="@+id/toggleSmartFilters"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:minWidth="0dp"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                />
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:textSize="16sp"
                    android:id="@+id/stickyFilterCheckbox"
                    android:textColor="?android:attr/textColorPrimary"
                    android:text="@string/persist_it"
                />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <!--    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/mainPurple"
        android:background="?attr/mainPurple"
        app:layout_anchor="@id/bottomSheet"
        app:layout_dodgeInsetEdges="bottom"
        app:borderWidth="0dp"
        android:src="@drawable/ic_filter_list_white_24dp"
        app:layout_anchorGravity="top|right|end"
        android:id="@+id/bsbutton"
        android:layout_margin="0dp"
        />-->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/mainPurple"
        android:background="?attr/mainPurple"
        app:tint="@android:color/white"
        app:layout_anchor="@id/bottomSheet"
        app:borderWidth="0dp"
        app:fabSize="mini"
        app:layout_anchorGravity="top|right|end"
        android:id="@+id/bsbutton"
        android:layout_margin="16dp"
    />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
