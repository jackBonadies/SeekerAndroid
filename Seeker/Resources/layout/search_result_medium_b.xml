<?xml version="1.0" encoding="utf-8" ?>
<!-- Style B: Two Line - three lines, username own line, metadata bottom row -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/relativeLayout1"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground"
    android:descendantFocusability="beforeDescendants"
    android:background="@drawable/cell_shape_end"
>
    <TextView
        android:id="@+id/folderNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:paddingStart="5dp"
        android:paddingTop="3dp"
        android:textColor="?attr/cellTextColor"
        android:textSize="14sp"
        android:textStyle="bold"
        android:singleLine="true"
    />
    <TextView
        android:id="@+id/userNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:paddingStart="5dp"
        android:paddingTop="1dp"
        android:textColor="@color/subTextColor"
        android:textSize="12sp"
        android:singleLine="true"
    />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/subLayout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="4dp"
        android:paddingTop="2dp"
    >
        <TextView
            android:id="@+id/fileTypeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/search_format_chip_bg"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginStart="5dp"
            android:textSize="10sp"
            android:textStyle="bold"
            android:singleLine="true"
        />
        <TextView
            android:id="@+id/speedTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:textColor="@color/subTextColor"
            android:textSize="12sp"
            android:singleLine="true"
        />
        <TextView
            android:id="@+id/queueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:textColor="@color/queueColor"
            android:textSize="12sp"
            android:singleLine="true"
            android:visibility="gone"
        />
        <TextView
            android:id="@+id/noSlotTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:textSize="10sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:visibility="gone"
        />
    </LinearLayout>
</LinearLayout>
