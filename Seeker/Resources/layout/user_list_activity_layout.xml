<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?attr/pseudo_window_background_color"
    android:id="@+id/userListMainLayoutId"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbarLayout"
        android:layout_width="match_parent"
        android:fitsSystemWindows="true"
        android:background="?attr/mainPurple"
        android:theme="@style/AppTheme.AppBarOverlay"
        android:layout_height="wrap_content"
    >
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/user_list_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/mainPurple"
            android:minHeight="100dp"
            app:popupTheme="@style/AppTheme.PopupOverlay"
            tools:layout_editor_absoluteX="0dp"
            tools:layout_editor_absoluteY="0dp"
        />
    </com.google.android.material.appbar.AppBarLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/userList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="0dp" />

        <LinearLayout
            android:id="@+id/noUsersView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:translationY="-48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/userlist_48"
                android:tint="?attr/cellTextColorSubdued" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_users_added"
                android:textSize="18sp"
                android:textColor="?attr/cellTextColor"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_users_subtitle"
                android:textSize="14sp"
                android:textColor="?attr/cellTextColorSubdued"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>
    <!--            <ListView
            android:minWidth="25px"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:minHeight="25px"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/userList" />-->
</LinearLayout>
