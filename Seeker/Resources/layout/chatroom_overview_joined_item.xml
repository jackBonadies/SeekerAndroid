<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
	android:paddingVertical="4dp"
	android:paddingHorizontal="6dp"
    android:orientation="horizontal"
    android:descendantFocusability="afterDescendants"
    android:id="@+id/linearLayoutChatroomOverview"
>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="6"
        android:orientation="horizontal"
        android:baselineAlignedChildIndex="0"
    >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/roomName"
			android:maxLines="1"
			android:ellipsize="end"
            android:text="roomNameDummy"
            android:textSize="22sp"
        />
        <ImageView
            android:layout_width="12sp"
            android:layout_height="12sp"
            android:layout_marginStart="6dp"
            android:id="@+id/unreadImageView"
            android:layout_gravity="center_vertical"
            android:visibility="gone"
            android:tint="@color/androidStockMessagesNewBlue"
            app:srcCompat="@drawable/checkbox_blank_circle"
        />
    </LinearLayout>
    <TextView
		android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="1000"
		android:fontFamily="sans-serif-monospace"
        android:id="@+id/usersInRoom"
        android:textSize="15sp"
        android:maxLines="1"
    />
    <ImageView
        android:layout_marginStart="6dp"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        app:srcCompat="@drawable/outline_cancel_white_24"
        android:id="@+id/leaveRoom"
        android:tint="?attr/mainTextColor"
    />
</LinearLayout>
