<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="android.PageFragment"
    android:id="@+id/relativeLayout1"
>
    <androidx.recyclerview.widget.RecyclerView
        android:layout_below="@id/header1"
        android:minWidth="25px"
        android:minHeight="25px"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/recyclerView1"
    />
    <LinearLayout
        android:id="@+id/noTransfersView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_centerInParent="true"
        android:translationY="-48dp">

        <ImageView
            android:id="@+id/noTransfersIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/download_48"
            android:tint="?attr/cellTextColorSubdued" />

        <TextView
            android:id="@+id/noTransfersHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_downloads"
            android:textSize="18sp"
            android:textColor="?attr/cellTextColor"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/noTransfersSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_downloads_subtitle"
            android:textSize="14sp"
            android:textColor="?attr/cellTextColorSubdued"
            android:layout_marginTop="4dp" />

    </LinearLayout>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/setUpSharing"
        android:id="@+id/setUpSharing"
        android:textSize="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:textAllCaps="false"
        android:minHeight="16dp"
        android:foreground="@drawable/button"
        style="@style/SeekerButtonStyle"
        android:layout_below="@id/noTransfersView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
    />
</RelativeLayout>
