<?xml version="1.0" encoding="utf-8" ?>
<!-- Modern style, file-type/bitrate chips on top row alongside folder name. Chevron + details container hidden by default; shown when used as Expandable. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:descendantFocusability="beforeDescendants"
>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
    >
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/relativeLayout1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
        >
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
            >
                <TextView
                    android:id="@+id/folderNameTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:textColor="?attr/cellTextColor"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/fileTypeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="2dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/bitrateTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:visibility="gone"
                />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/subLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingBottom="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="12dp"
            >
                <TextView
                    android:id="@+id/userNameTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:paddingStart="12dp"
                    android:paddingEnd="6dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/fileCountTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/file_stacks_drawable"
                    android:drawablePadding="2dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/speedTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/download_search_drawable"
                    android:drawablePadding="0dp"
                    android:paddingStart="8dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/queueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="6dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:visibility="gone"
                />
            </LinearLayout>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/expandClickArea"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:background="?attr/expandableModernChevronBg"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
        >
            <ImageView
                android:id="@+id/expandableClick"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:tint="?attr/expandIconColor"
                app:srcCompat="@drawable/ic_expand_more_black_32dp"
            />
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/detailsExpandable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/expandableModernFilesBg"
        android:paddingStart="18dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
    />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slightTint"
    />
</LinearLayout>
