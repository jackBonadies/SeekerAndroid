<?xml version="1.0" encoding="utf-8" ?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
>
    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/abc_action_bar_content_inset_material"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    >
        <TextView
            android:text="@string/search_tabs_header"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/mainTextColorHinted"
            android:letterSpacing="0.05"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="6dp"
        />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/slightContrastColor"
            android:layout_marginBottom="4dp"
        />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/searchesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/createNewSearch"
            android:text="@string/new_search_tab"
            android:textColor="?attr/mainPurple"
            android:background="@drawable/search_tab_new_search_outline"
            android:drawableStart="@drawable/ic_add_circle_outline"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/mainPurple"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginTop="4dp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
        />
        <TextView
            android:layout_marginTop="20dp"
            android:text="@string/wishlist_header"
            android:id="@+id/wishlistTitle"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/mainTextColorHinted"
            android:letterSpacing="0.05"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="6dp"
        />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/slightContrastColor"
            android:layout_marginBottom="4dp"
        />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/wishlistsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        />
    </LinearLayout>
</ScrollView>
