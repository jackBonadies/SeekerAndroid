<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/parentLayout"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingStart="6dp"
    android:paddingEnd="4dp"
>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/relativeLayout1"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:gravity="center_vertical"
    >
        <TextView
            android:id="@+id/textViewFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="?attr/cellTextColor"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
        />

        <TextView
            android:id="@+id/textViewUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="end"
            android:maxWidth="140dp"
            android:textSize="11sp"
            android:textColor="@color/transferUsernameSubdued"
            android:singleLine="true"
        />
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/relativeLayout2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
    >
        <View
            android:id="@+id/statusDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/transfer_status_dot"
            android:layout_marginStart="4dp"
        />

        <TextView
            android:id="@+id/textViewStatusAdditionalInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:layout_marginStart="5dp"
            android:textSize="11sp"
            android:singleLine="true"
        />

        <TextView
            android:id="@+id/textViewSizeSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" \u00b7 "
            android:layout_marginStart="3dp"
            android:layout_marginEnd="2dp"
            android:textSize="11sp"
            android:textColor="?attr/cellTextColor"
        />

        <TextView
            android:id="@+id/textViewSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="?attr/cellTextColor"
        />

        <ProgressBar
            android:id="@+id/simpleProgressBar"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:layout_marginTop="1dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="6dp"
            android:progressDrawable="@drawable/transfer_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="100"
        />

        <TextView
            android:id="@+id/textViewSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"
        />
    </LinearLayout>
</LinearLayout>
