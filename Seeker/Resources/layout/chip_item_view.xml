<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:id="@+id/chipLayout"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:orientation="horizontal"
>
    <com.google.android.material.chip.Chip
        android:text="mp3"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:id="@+id/chip1"
        app:chipBackgroundColor="@drawable/chip_background_state_color"
        app:chipStrokeColor="@drawable/chip_stroke_state_color"
        app:chipStrokeWidth="1dp"
        app:checkedIconVisible="true"
        app:checkedIconTint="@android:color/white"
        android:textColor="@drawable/chip_text_color_state"
        style="@style/Widget.MaterialComponents.Chip.Filter"
        android:layout_height="wrap_content"
    />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/chipSeparator"
        android:paddingStart="4dp"
        android:textSize="20dp"
        android:textColor="@color/chipSeparatorColor"
        android:layout_margin="0dp"
        android:visibility="visible"
        android:text="•"
        android:textStyle="bold"
        android:layout_gravity="center_vertical"
    />
</LinearLayout>
