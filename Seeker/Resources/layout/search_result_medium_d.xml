<?xml version="1.0" encoding="utf-8" ?>
<!-- Style D: Status Bar (card with chips on bottom row) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/relativeLayout1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground"
    android:descendantFocusability="beforeDescendants"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/dialog_background"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
    >
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
        >
            <TextView
                android:id="@+id/folderNameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:textColor="?attr/cellTextColor"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:singleLine="true"
            />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/subLayout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
            >
                <TextView
                    android:id="@+id/userNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:paddingEnd="6dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/fileCountTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/file_stacks_drawable"
                    android:drawablePadding="2dp"
                    android:paddingEnd="6dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/fileTypeTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/bitrateTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:visibility="gone"
                />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                />
                <TextView
                    android:id="@+id/speedTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:textColor="@color/subTextColor"
                    android:textSize="12sp"
                    android:singleLine="true"
                />
                <TextView
                    android:id="@+id/queueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:visibility="gone"
                />
                <TextView
                    android:id="@+id/noSlotTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/search_format_chip_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginStart="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:visibility="gone"
                />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
